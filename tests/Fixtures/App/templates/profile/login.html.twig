{% extends 'base.html.twig' %}

{% block title %}Login - Playwright Symfony{% endblock %}

{% block hero_title %}Login{% endblock %}

{% block content %}
    <div class="content" style="max-width: 500px; margin: 2rem auto;">
        <h1 style="color: #667eea; margin-bottom: 1rem;">Authentication Required</h1>

        <p style="color: #666; margin-bottom: 2rem;">
            Please authenticate to access protected pages.
        </p>

        <form method="POST" action="/profile/login">
            <label for="username">Username:</label>
            <input type="text" id="username" name="username" required autofocus>

            <label for="password">Password:</label>
            <input type="password" id="password" name="password" required>

            <button type="submit">Login</button>
        </form>
    </div>
{% endblock %}
